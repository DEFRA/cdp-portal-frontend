{% from "time/macro.njk" import appTime %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

<tr class="{{ params.rowClasses }}" data-testid="app-entity-table-row-{{ params.loopIndex }}">
  <td headers="eventType" class="app-entity-table__cell" data-label="eventType">
    {{ govukTag({
      text: params.eventType,
      classes: "app-tag govuk-tag",
      attributes: { "data-testid": "govuk-tag" }
    }) }}
  </td>

  <td headers="channel" class="app-entity-table__cell" data-label="channel">
    <a class="app-link app-link--underline"
      href="https://defra-digital-team.slack.com/app_redirect?channel={{ params.channel }}" rel="noopener noreferrer" target="window"
    data-testid="app-link">#{{ params.channel }}</a>
  </td>

  {% for env in params.envs %}
    <td headers="{{ env.id }}" class="app-entity-table__cell" data-label="{{ env.id }}">
      {% if env.selected %}
      <div class="app-check" data-testid="check-{{ env.id }}"></div>
      {% else %}
      - - -
      {% endif %}
    </td>
  {% endfor %}

  <td headers="status" class="app-entity-table__cell" data-label="status">
    {% if params.enabled %}
      {{ govukTag({
        text: 'Enabled',
        classes: "app-tag govuk-tag--green",
        attributes: { "data-testid": "govuk-tag" }
      }) }}
    {% else %}
      {{ govukTag({
        text: 'Disabled',
        classes: "app-tag govuk-tag--grey",
        attributes: { "data-testid": "govuk-tag" }
      }) }}
    {% endif %}
  </td>

   <td headers="actions" class="app-entity-table__cell" data-label="actions">
     <div class="app-entity">
      <div>
        <a class="app-link app-link--underline"
          href="/test-suites/{{ params.serviceId }}/notifications/{{ params.id }}/update"
        data-testid="app-link">Update</a>
      </div>
      <div class="govuk-!-margin-left-1">
        <a class="app-link app-link--underline"
          href="/test-suites/{{ params.serviceId }}/notifications/{{ params.id }}/remove"
        data-testid="app-link">Remove</a>
      </div>
     </div>
   </td>
</tr>
