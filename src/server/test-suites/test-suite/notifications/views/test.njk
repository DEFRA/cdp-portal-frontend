{% extends "layouts/tabbed-page.njk" %}

{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "icons/info-icon/macro.njk" import appInfoIcon %}

{% set helpHtml %}
  <p class="govuk-!-margin-bottom-1">
    Before notifications can be sent to a Slack channel you must add the <strong>CDP Bot</strong> slack integration to the channel.
    <br><br>
    See the <a href='/documentation/how-to/testing/test-notifications.md#add-cdp-bot-to-the-channel' target='_blank'>docs</a> for information on how set this up.
  </p>
{% endset %}

{% set debugHtml %}
  <p class="govuk-!-margin-bottom-1">
    If the notification was not delivered to your channel check the following:
  </p>
  <ol>
    <li>The Slack channel exists in the <strong>defra-digital-team.slack.com</strong> (grey) workspace.</li>
    <li>The CDP Bot has been added to the channel.</li>
    <li>Check the <a class="app-link" href="https://defra-digital-team.slack.com/archives/C0ASJR4402W" target="_blank" rel="noopener noreferrer">#cdp-notification-failures</a> channel, failed notifications are reported here.</li>
  </ol>
{% endset %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Remove Notification",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
<section class="govuk-!-margin-top-6">
  {% call appSplitPane() %}
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half-from-desktop">
        <div data-testid="remove-test-run">
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2" data-testid="remove-test-run-heading">
            Test Notification
          </h2>
          <p class="govuk-!-margin-bottom-2">
            Validate the notification is configured correctly and can be delivered via Slack.
          </p>

          <div class="govuk-!-margin-bottom-4">
            {{ appInfo({
              html: helpHtml
            }) }}
          </div>

          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Test Suite</h3>
          <p class="govuk-!-margin-bottom-2">
            <a
              href="{{ routeLookup('test-suites/{serviceId}', { params: { serviceId : entity.name } }) }}"
              class="govuk-link app-link">
              {{ entity.name }}
            </a>
          </p>

          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Slack channel</h3>
          <p>
            <a href="https://defra-digital-team.slack.com/app_redirect?channel={{ notification.slackChannel }}">#{{ notification.slackChannel | safe }}</a>
          </p>

          <form action="/test-suites/{{ entity.name }}/notifications/{{ notification.ruleId }}/test/action" method="post">
            <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />

            <div class="govuk-body govuk-button-group govuk-!-margin-top-7">
              {{ govukButton({
                classes: "app-button",
                text: "Send test notification"
              }) }}

              <a class="app-link" href="{{ routeLookup('test-suites/{serviceId}/notifications', {
                params: { serviceId: entity.name }
              }) }}">Cancel</a>
            </div>
          </form>

          <div class="govuk-!-margin-bottom-4">
            {{ appInfo({
              html: debugHtml
            }) }}
          </div>

        </div>
      </div>
    </div>

  {% endcall %}
</section>
{% endblock %}
