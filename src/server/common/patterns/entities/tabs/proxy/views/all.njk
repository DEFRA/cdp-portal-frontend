{% extends "layouts/tabbed-page.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}

{% from "info/macro.njk" import appInfo %}
{% from "../components/proxy-rule-row/macro.njk" import proxyRuleRow %}


{% set explainProxyRulesHtml %}
  For more information,
  and how to modify the rules, follow the <a class="app-link app-link--underline app-link--text-colour"
                                             href="https://portal.cdp-int.defra.cloud/documentation/how-to/proxy.md"
                                             target="_blank"
                                             rel="noopener noreferrer">proxy documentation</a>
{% endset %}





{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Proxy",
    text: entityName
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}


{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <section>
            <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Proxy</h2>
            <p class="govuk-!-margin-bottom-2">
              View proxy rules for {{ entityName }} in all CDP environments.
              These are rules for allowing outbound traffic from the {{ entityKind }} to anything outside CDP.
            </p>

            {{ appInfo({ html: explainProxyRulesHtml }) }}


            <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Service proxy rules</h3>

            <p class="govuk-!-margin-bottom-2">
              Service specific proxy rules for your {{ entityKind }}
            </p>

            {% call(params) appEntityTable(allowedTable) %}

              {{ proxyRuleRow({
                rowClasses: params.rowClasses,
                loopIndex: params.loopIndex,
                envs: params.row.envs
              }) | safe }}

            {% endcall %}

            <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Platform proxy rules</h3>
            <p class="govuk-!-margin-bottom-2">
              Platform level proxy rules for your {{ entityKind }}
            </p>
            {{ appInfo({
              classes: "govuk-!-margin-bottom-4",
              text: "These proxy rules are set by the platform. They cannot be changed."
            }) }}

            {% call(params) appEntityTable(defaultTable) %}

              {{ proxyRuleRow({
                rowClasses: params.rowClasses,
                loopIndex: params.loopIndex,
                envs: params.row.envs
              }) | safe }}

            {% endcall %}
          </section>
        {% endcall %}

      </div>
    </div>
  </section>

{% endblock %}
