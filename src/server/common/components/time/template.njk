{% from "tool-tip/macro.njk" import appToolTip %}

{% set content %}
  {% if params.text %}
    {{ params.text }}
  {% elseif params.withoutSeconds %}
    {{ params.datetime | formatDate("do MMM yyyy 'at' HH:mm") }}
  {% elseif params.formatString %}
    {{ params.datetime | formatDate(params.formatString) }}
  {% else %}
    {{ params.datetime | formatDate("do MMM yyyy 'at' HH:mm:ss") }}
  {% endif %}
{% endset %}

{% set timeHtml %}
  <time{% if params.classes %} class="{{ params.classes }}"{% endif %}
    datetime="{{ params.datetime | relativeDate }}"
    data-testid="app-time">
    {{ content }}
  </time>
{% endset %}

{% if params.withoutTooltip or not params.datetime %}
  {{ timeHtml | safe }}
{% else %}
  {% call appToolTip({ text: (params.datetime | formatDistanceToNow) ~ ' ago' }) %}
    {{ timeHtml | safe }}
  {% endcall %}
{% endif %}



