{% extends "layouts/page.njk" %}
{% from "icons/tick-icon/macro.njk" import appTickIcon %}
{% from "icons/error-icon/macro.njk" import appErrorIcon %}
{% from "availability/macro.njk" import appAvailability %}

{% block content %}
  {{ appStepNavigation(stepNavigation) }}

  <div class="govuk-main-wrapper app-main-wrapper"">

    {{ appPageHeading({
      caption: "Create",
      text: "Microservice",
      intro: "With associated dashboards, proxy and infrastructure"
    }) }}

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third-from-desktop-wide">
        <section class="govuk-!-margin-bottom-8">
          <form action="/create/microservice/detail" method="post" data-js="app-form-errors"
                class="govuk-!-margin-bottom-4">
            <input type="hidden" name="csrfToken" value="{{ csrfToken }}"/>
            <input type="hidden" name="redirectLocation" value="{{ redirectLocation }}"/>

            {% call govukFieldset() %}

              {{ govukInput({
                label: {
                  text: "Name",
                  classes: "app-label"
                },
                id: "name",
                name: "microserviceName",
                classes: "app-input app-input--wide",
                hint: {
                  html: "Lowercase letters, numbers and hyphens. Maximum 32 characters",
                  classes: "app-hint"
                },
                formGroup: {
                  classes: "app-form-group app-form-group-js"
                },
                value: formValues.microserviceName,
                attributes: {
                  "data-js": "app-availability app-input-assistant",
                  "data-availability-target-id": "name-availability",
                  "data-input-assistant-target-id": "name-input-assistant",
                  "data-1p-ignore": ""
                },
                errorMessage: errorMessageHelper(formErrors.microserviceName.message),
                suffix: {
                  classes: "app-input__suffix",
                  html: appAvailability({
                    dataFetcher: "fetchIsNameAvailable",
                    targetId: "name-availability"
                  })
                }
              }) }}

              {{ appInputAssistant({
                message: "That name is not ideal. Read “Naming conventions” for some tips",
                targetId: "name-input-assistant"
              }) }}

              {{ govukSelect({
                id: "service-type",
                name: "serviceTypeTemplateId",
                label: {
                  text: "Template",
                  classes: "app-label"
                },
                classes: "app-select",
                hint: {
                  text: "The template your microservice is created from",
                  classes: "app-hint"
                },
                formGroup: {
                  classes: "app-form-group app-form-group-js"
                },
                value: formValues.serviceTypeTemplateId,
                errorMessage: errorMessageHelper(formErrors.serviceTypeTemplateId.message),
                items: serviceTemplateIdOptions
              }) }}

              {% include "create/partials/branch-text-input.njk" %}

              {{ govukSelect({
                id: "team-id",
                name: "teamId",
                label: {
                  text: "Owning Team",
                  classes: "app-label"
                },
                classes: "app-select",
                value: formValues.teamId,
                hint: {
                  text: "The CDP team that will own your microservice",
                  classes: "app-hint"
                },
                formGroup: {
                  classes: "app-form-group app-form-group-js"
                },
                errorMessage: errorMessageHelper(formErrors.teamId.message),
                items: teamsOptions
              }) }}

            {% endcall %}

            {{ govukButton({
              classes: "app-button",
              text: formButtonText
            }) }}
          </form>
        </section>
      </div>

      <div class="govuk-grid-column-two-thirds-from-desktop-wide">
        {% call appPanel() %}
          <section>

            {{ appNamingAdvice({
              kind: "microservice",
              goodSuffixes: ["frontend", "ui", "backend", "api", "prototype"],
              badSuffixes: ["alpha", "v1", "main", "repo", "new", "hapi"],
              badExamples: ["sv-frontend"],
              exampleName: "seed-bank"
            } ) }}
          </section>
        {% endcall %}

        {% call appPanel() %}
          <section>
            <h2 class="govuk-heading-m govuk-!-margin-bottom-3">Templates</h2>

            <p class="govuk-!-margin-bottom-0">
              <a class="app-link" href="https://github.com/DEFRA/cdp-node-frontend-template" target="_blank"
                 rel="noopener noreferrer">
                Node.js Frontend</a> - Hapi.js frontend app with
              <a class="app-link" href="https://design-system.service.gov.uk" target="_blank" rel="noopener noreferrer">GOV.UK
                Frontend</a>
              (Nunjucks, JS, Sass) + Redis
            </p>

            <p class="govuk-!-margin-bottom-0">
              <a class="app-link" href="https://github.com/DEFRA/cdp-node-backend-template" target="_blank"
                 rel="noopener noreferrer">
                Node.js Backend</a> - Hapi.js API service + MongoDB
            </p>

            <p class="govuk-!-margin-bottom-0">
              <a class="app-link" href="https://github.com/DEFRA/cdp-node-backend-no-db-template" target="_blank"
                 rel="noopener noreferrer">
                Node.js Backend (Minimal)</a> - minimal Hapi.js API service, no database
            </p>

            <p class="govuk-!-margin-bottom-0">
              <a class="app-link" href="https://github.com/DEFRA/cdp-dotnet-backend-template" target="_blank"
                 rel="noopener noreferrer">
                .NET Backend</a> - .NET API service + MongoDB
            </p>

            {% if hasScope(scopes.restrictedTechPython) %}
              <p class="govuk-!-margin-bottom-0">
                <a class="app-link" href="https://github.com/DEFRA/cdp-python-backend-template" target="_blank"
                   rel="noopener noreferrer">
                  Python Backend</a> - Python API service + MongoDB
              </p>
            {% endif %}

          </section>
        {% endcall %}
      </div>
    </div>
  </div>
{% endblock %}
