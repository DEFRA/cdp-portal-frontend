{% extends "layouts/tabbed-page.njk" %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Resources",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <span class="govuk-caption-l">Management</span>
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Topology</h2>
          <p class="govuk-!-margin-bottom-2">
            Provides a visual representation of <strong>cdp-portal-backend's</strong> network dependencies and consumers, allowing you to quickly understand the relationships between various components in your system.
          </p>

          <style>

          svg .icon-shape p, svg .labelBkg {
            background: none !important;
          }


          svg .edge-animation-slow {
            animation-direction: reverse !important;
          }

          svg .edge-pattern-dotted {
            stroke: #DDD !important;
            stroke-dasharray: none !important;
          }

          </style>
          <pre class="mermaid">
              flowchart TD
                subgraph platform[Platform]
                  style platform fill:#fff,stroke-dasharray:10 5

                  subgraph cdp-portal-backend[ ]
                    direction TD
                      service@{ icon: "logos:aws-fargate", label: "<strong>cdp-portal-backend</strong>"}

                      s31@{ icon: "logos:aws-s3", label: "cdp-portal-backend"}
                      service -.- s31

                      sqs1@{ icon: "logos:aws-sqs", label: "message_clearance_request"}
                      service -.- sqs1
                      sqs1 e1@==>|Subscription| sns2
                      e1@{ animation: slow }

                      sns2@{ icon: "logos:aws-sns", label: "error_notification.fifo"}
                      service -.- sns2

                      sns1@{ icon: "logos:aws-sns",label: "decision_notification.fifo"}
                      service -.- sns1
                    end

                    subgraph cdp-portal-frontend[ ]
                      direction TD
                      service2@{ icon: "logos:aws-fargate", label: "<a href="/">cdp-portal-frontend</a>"}

                      sqs11@{ icon: "logos:aws-sqs", label: "error_message"}
                      service2 -.- sqs11

                       sqs11 e11@==>|Subscription| sns2
                      e11@{ animation: slow }
                    end
                  end

                  subgraph anotherteam[Another team]
                    style anotherteam fill:#fff,stroke-dasharray:10 5

                    subgraph exp-service[ ]
                      direction TD
                      service3@{ icon: "logos:aws-fargate", label: "<a href="/">exp-service-backend</a>"}

                      service3 ==>|Read| s31

                      sqs12@{ icon: "logos:aws-sqs", label: "decision_message"}
                      service3 -.- sqs12

                      sqs12 e12@==>|Subscription| sns1
                      e12@{ animation: slow }
                    end
                  end
            </pre>
        {% endcall %}

      </div>
    </div>
  </section>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
