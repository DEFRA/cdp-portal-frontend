{% extends "layouts/tabbed-page.njk" %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Diagnostics",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <span class="govuk-caption-l">{{environment | formatText}}</span>
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Diagnostics</h2>
          <p class="govuk-!-margin-bottom-2">
            Provides a visual representation of <strong>{{entity.name}}'s</strong> network dependencies and consumers, allowing you to quickly understand the relationships between various components in your system.
          </p>

          <pre class="mermaid mermaid--no-label-background mermaid--light-links mermaid--icon-tooltips">
            flowchart LR
              subgraph network[" "]
                style network fill:#fff,stroke-dasharray:10 5
                direction TD

                subgraph ingress[Ingress]
                  direction LR

                  {% if entity.subType == 'Frontend' %}
                    browser@{ icon: "logos:chrome", label: "Browser"}
                    browser browser_link@--> waf
                    browser_link@{ animation: slow }
                  {% else %}
                    {% if entity.environments[environment].api_gateway%}
                      client@{ icon: "logos:postman-icon", label: "External client"}
                      client client_link@--> api
                      client_link@{ animation: slow }

                      api@{ icon: "logos:aws-api-gateway", label: "<a href="/">API gateway logs</a>"}
                      api api_link@--> waf
                      api_link@{ animation: slow }
                    {% endif %}

                    frontend@{ icon: "logos:aws-fargate", label: "Frontend service"}
                    frontend frontend_link@--> waf
                    frontend_link@{ animation: slow }
                  {% endif %}

                  waf@{ icon: "logos:aws-waf", label: "<a href="/">WAF logs</a>"}

                  alb@{ img: "{{ getAssetPath("src/client/images/application-load-balancer.svg") }}", h: 48, w: 48, constraint: 'on', label: "<a href="/">ALB logs</a>"}

                  nginx@{ icon: "logos:nginx", label: "<a href="/">Nginx logs</a>"}

                  sslSidecar@{ icon: "logos:docker-icon", label: "<a href="/">SSL sidecar logs</a>"}

                  waf waf_link@--> alb
                  waf_link@{ animation: slow }

                  alb alb_link@--> nginx
                  alb_link@{ animation: slow }

                  nginx nginx_link@--> sslSidecar
                  nginx_link@{ animation: slow }
                end

                subgraph egress[Egress]
                  direction RL

                  forwarder@{ icon: "logos:docker-icon", label: "<a href="/">Forwarder proxy logs</a>"}

                  squid@{ img: "{{ getAssetPath("src/client/images/squid.jpeg") }}", h: 48, w: 48, constraint: 'on', label: "<a href="/">Squid proxy logs</a>"}

                  internet@{ img: "{{ getAssetPath("src/client/images/cloud.svg") }}", h: 40, w: 40, constraint: 'on', label: "Internet"}

                  forwarder forwarder_link@--> squid
                  forwarder_link@{ animation: slow }

                  squid squid_link@--> internet
                  squid_link@{ animation: slow }
                end

                ingress ~~~ egress
              end

              subgraph app[Service / Resources]
                direction LR

                service@{ icon: "logos:aws-fargate", label: "<a href="/">Service logs</a>"}

                metrics@{ icon: "logos:aws-open-search", label: "<a href="/">Metrics logs</a>"}
                service -.- metrics

                {% if entity.subType == 'Frontend' %}
                  reddis@{ icon: "logos:aws-elastic-cache", label: "<a href="/">Reddis logs</a>"}
                  service -.- reddis
                {% else %}
                  mongo@{ icon: "logos:mongodb-icon", label: "<a href="/">Mongo logs</a>"}
                  service -.- mongo

                  {% if entity.environments[environment].sql_database%}
                    postgress@{ icon: "logos:postgresql", label: "<a href="/">PostgreSQL logs</a>"}
                    service -.- postgress
                  {% endif %}
                {% endif %}

              end

              network ~~~ app

             </pre>
        {% endcall %}

      </div>
    </div>
  </section>


{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
