{% extends "layouts/tabbed-page.njk" %}
{% from "tool-tip/macro.njk" import appToolTip %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "./components/traffic-flow/macro.njk" import trafficFlow %}
{% from "./components/dashboards/macro.njk" import dashboards %}
{% from "./components/alerts/macro.njk" import alerts %}


{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Diagnostics",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <span class="govuk-caption-l">{{environment | formatText}}</span>
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Diagnostics</h2>
          <p class="govuk-!-margin-bottom-2">
            Provides a visual representation of traffic flow for <strong>{{entity.name}}</strong> allowing you to quickly understand the stages in the platform and view logs and metrics for those stages.
          </p>

          {% if serviceDeployedInEnvironment %}

              {{ trafficFlow(environment, entity, resources, getAssetPath, logViewUrl, renderLinks, apigwMetricLink) }}

              {% if userIsAdmin %}
                <div class="govuk-grid-row govuk-!-margin-top-8">
                  {{ dashboards(environment, resources.metrics, createDashboardRows) }}
                  {{ alerts(environment, resources.alerts, createAlertRows) }}
                </div>
              {% endif %}

          {% else %}

            {{ appInfo({ text: "Service not deployed in this environment" }) }}

          {% endif %}
       {% endcall %}

      </div>
    </div>

  </section>


{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
