{% extends "layouts/tabbed-page.njk" %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Diagnostics",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <span class="govuk-caption-l">{{environment | formatText}}</span>
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Diagnostics</h2>
          <p class="govuk-!-margin-bottom-2">
            Provides a visual representation of <strong>{{entity.name}}'s</strong> network dependencies and consumers, allowing you to quickly understand the relationships between various components in your system.
          </p>

          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Frontend</h3>

          <pre class="mermaid mermaid--no-label-background mermaid--light-links mermaid--icon-tooltips">
            flowchart LR
              subgraph internet["Internet"]
                client@{ icon: "logos:chrome", label: "Browser"}
              end

              subgraph network[" "]
                style network fill:#fff,stroke-dasharray:10 5
                direction TD

                subgraph ingress[Ingress]
                  direction LR

                  waf@{ icon: "logos:aws-waf", label: "<a href="/">WAF logs</a>"}

                  alb@{ img: "{{ getAssetPath("src/client/images/application-load-balancer.svg") }}", h: 48, w: 48, constraint: 'on', label: "<a href="/">ALB logs</a>"}

                  nginx@{ icon: "logos:nginx", label: "<a href="/">Nginx logs</a>"}

                  sslSidecar@{ icon: "logos:docker-icon", label: "<a href="/">SSL sidecar logs</a>"}

                  waf e1@--> alb
                  e1@{ animation: slow }

                  alb e2@--> nginx
                  e2@{ animation: slow }

                  nginx e3@--> sslSidecar
                  e3@{ animation: slow }
                end

                subgraph egress[Egress]
                  direction RL

                  forwarder@{ icon: "logos:docker-icon", label: "<a href="/">Forwarder proxy logs</a>"}

                  squid@{ icon: "logos:nginx", label: "<a href="/">Squid proxy logs</a>"}

                  forwarder e4@--> squid
                  e4@{ animation: slow }
                end

                ingress ~~~ egress
              end

              subgraph app[Service / Resources]
                direction LR

                service@{ icon: "logos:aws-fargate", label: "<a href="/">Service logs</a>"}

                metrics@{ icon: "logos:aws-open-search", label: "<a href="/">Metrics logs</a>"}

                reddis@{ icon: "logos:aws-elastic-cache", label: "<a href="/">Reddis logs</a>"}

                service -.- metrics
                service -.- reddis
              end

              internet ~~~ network
              network ~~~ app

             </pre>





             <h3 class="govuk-heading-m govuk-!-margin-bottom-2">Backend</h3>

             <pre class="mermaid mermaid--no-label-background mermaid--light-links mermaid--icon-tooltips">
               flowchart LR
                 subgraph internet["Internet"]
                   client@{ icon: "logos:postman-icon", label: "Client"}
                 end

                 subgraph network[" "]
                   style network fill:#fff,stroke-dasharray:10 5
                   direction TD

                   subgraph ingress[Ingress]
                     direction LR

                     api@{ icon: "logos:aws-api-gateway", label: "API gateway logs"}

                     waf@{ icon: "logos:aws-waf", label: "WAF logs"}

                     alb@{ img: "{{ getAssetPath("src/client/images/application-load-balancer.svg") }}", h: 48, w: 48, constraint: 'on', label: "ALB logs"}

                     nginx@{ icon: "logos:nginx", label: "Nginx logs"}

                     sslSidecar@{ icon: "logos:docker-icon", label: "SSL sidecar logs"}

                     api e1@--> waf
                     e1@{ animation: slow }

                     waf e2@--> alb
                     e2@{ animation: slow }

                     alb e3@--> nginx
                     e3@{ animation: slow }

                     nginx e4@--> sslSidecar
                     e4@{ animation: slow }
                   end

                   subgraph egress[Egress]
                     direction RL

                     forwarder@{ icon: "logos:docker-icon", label: "Forwarder proxy logs"}

                     squid@{ icon: "logos:nginx", label: "Squid proxy logs"}

                     forwarder e5@--> squid
                     e5@{ animation: slow }
                   end

                   ingress ~~~ egress
                 end

                 subgraph app[Service / Resources]
                   direction LR

                   service@{ icon: "logos:aws-fargate", label: "Service logs"}

                   metrics@{ icon: "logos:aws-open-search", label: "Metrics logs"}

                   mongo@{ icon: "logos:mongodb-icon", label: "Mongo logs"}

                   postgress@{ icon: "logos:postgresql", label: "PostgreSQL logs"}

                   service -.- metrics
                   service -.- mongo
                   service -.- postgress
                 end

                 internet ~~~ network
                 network ~~~ app

              </pre>

        {% endcall %}

      </div>
    </div>
  </section>


{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
