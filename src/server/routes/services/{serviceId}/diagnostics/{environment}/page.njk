{% extends "layouts/tabbed-page.njk" %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Diagnostics",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <span class="govuk-caption-l">{{environment | formatText}}</span>
          <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Diagnostics</h2>
          <p class="govuk-!-margin-bottom-2">
            Provides a visual representation of <strong>{{entity.name}}'s</strong> network dependencies and consumers, allowing you to quickly understand the relationships between various components in your system.
          </p>

          <script>
            window.linkMenu = function linkMenu(nodeId) {
              alert(nodeId)
            }
          </script>

          <pre class="mermaid mermaid--no-label-background mermaid--light-links mermaid--icon-tooltips">
            flowchart LR
              subgraph network[" "]
                style network fill:#fff,stroke-dasharray:10 5
                direction TD

                subgraph ingress[Ingress]
                  direction LR

                  {% if entity.subType == 'Frontend' %}
                    browser@{ icon: "logos:chrome", label: "Browser"}
                    browser browser_link@--> waf
                    browser_link@{ animation: slow }
                  {% else %}
                    {% if resources.tenant_config.api_gateway %}
                      client@{ icon: "logos:postman-icon", label: "External client"}
                      client client_link@--> api
                      client_link@{ animation: slow }

                      api@{ icon: "logos:aws-api-gateway", label: "{{ renderLinks('API Gateway', logViewUrl('api-gw-private'), resources.metrics.apigw.url) }}"}
                      api api_link@--> waf
                      api_link@{ animation: slow }
                    {% endif %}

                    frontend@{ icon: "logos:aws-fargate", label: "Frontend service"}
                    frontend frontend_link@--> waf
                    frontend_link@{ animation: slow }
                  {% endif %}

                  waf@{ icon: "logos:aws-waf", label: "{{ renderLinks('WAF') }}"}

                  alb@{ img: "{{ getAssetPath("src/client/images/application-load-balancer.svg") }}", h: 48, w: 48, constraint: 'on', label: "{{ renderLinks('ALB') }}"}

                  nginx@{ icon: "logos:nginx", label: "{{ renderLinks('Nginx', 'nginx-public' if entity.subType == 'Frontend' else 'nginx-protected') }}"}

                  sslSidecar@{ icon: "logos:docker-icon", label: "{{ renderLinks('SSL', 'ssl-sidecar') }}"}

                  waf waf_link@--> alb
                  waf_link@{ animation: slow }

                  alb alb_link@--> nginx
                  alb_link@{ animation: slow }

                  nginx nginx_link@--> sslSidecar
                  nginx_link@{ animation: slow }
                end

                subgraph egress[Egress]
                  direction RL

                  forwarder@{ icon: "logos:docker-icon", label: "{{ renderLinks('Forwarder proxy', logViewUrl('forwarder-proxy')) | safe }}"}

                  squid@{ img: "{{ getAssetPath("src/client/images/squid.jpeg") }}", h: 48, w: 48, constraint: 'on', label: "{{ renderLinks('Squid proxy', logViewUrl('squid-proxy')) | safe }}"}

                  internet@{ img: "{{ getAssetPath("src/client/images/cloud.svg") }}", h: 40, w: 40, constraint: 'on', label: "Internet"}

                  forwarder forwarder_link@--> squid
                  forwarder_link@{ animation: slow }

                  squid squid_link@--> internet
                  squid_link@{ animation: slow }
                end

                ingress ~~~ egress
              end

              subgraph app[Service / Resources]
                direction LR

                service@{ icon: "logos:aws-fargate", label: "{{ renderLinks('Service', logViewUrl('app'), resources.metrics.service.url) | safe }}"}

                {% if entity.subType == 'Frontend' %}
                  redis@{ icon: "logos:aws-elastic-cache", label: "{{ renderLinks('Redis') }}"}
                {% else %}
                  {% if resources.tenant_config.mongo%}
                    mongo@{ icon: "logos:mongodb-icon", label: "{{ renderLinks('MongoDB', logViewUrl('mongo'), resources.metrics.mongodb.url) | safe }}'>Metrics</a>"}
                  {% endif %}

                  {% if resources.tenant_config.sql_database%}
                    postgress@{ icon: "logos:aws-aurora", label: "{{ renderLinks('PostgreSQL') | safe }}"}
                  {% endif %}
                {% endif %}

              end

              network ~~~ app


             </pre>
        {% endcall %}

      </div>
    </div>
  </section>


{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
