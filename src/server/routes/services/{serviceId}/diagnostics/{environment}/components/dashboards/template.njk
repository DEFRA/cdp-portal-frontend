{% from "panel/macro.njk" import appPanel %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "info/macro.njk" import appInfo %}
{% from "loader/macro.njk" import appLoader %}

<div
  class="govuk-grid-column-one-half"
  data-xhr="dashboards-playground-load"
  data-xhr-stop="{{ false if playground.status == 'LOADING' else true }}" data-js="app-poll"
  data-poll-url=""
  data-poll-interval="3000"
  data-poll-limit="100"
>

  <h3 class="govuk-heading-l govuk-!-margin-bottom-4" id="dashboards">
    Dashboards
  </h3>

  {% call appPanel({
    classes: "govuk-!-margin-bottom-6"
  }) %}
    {{ govukTable({
      classes: "app-table app-table--inverse govuk-!-margin-top-3 govuk-!-margin-bottom-3",
      head: [
        { text: "Type" },
        { text: "Name" },
        { text: "Version" }
      ],
      rows: createDashboardRows(metrics)
    }) }}

  {% endcall %}

  {% call appPanel() %}
    <h3 class="govuk-heading-m govuk-!-margin-bottom-1">Dashboards playground</h3>

    <p class="govuk-!-margin-bottom-3">
      Custom dashboards are managed in the the playground and promoted up to the other environments.  View the <a href="/documentation/how-to/monitoring.md#creating-custom-dashboards" target="_blank" rel="noopener noreferrer">CDP documentation</a>.
    </p>

    {% if environment.endsWith('dev') %}

      {% if playground.status == 'LOADING' %}

        {{ appLoader({ classes: "app-loader--is-loading govuk-!-margin-bottom-4 govuk-!-margin-top-4" }) }}

      {% else %}

        {{ govukTable({
          classes: "app-table app-table--inverse govuk-!-margin-bottom-4",
          head: [
            { text: "Type" },
            { text: "Dashboard" },
            { text: "Version" },
            { text: "Action" } if environment.endsWith('dev') and showPromote and playground.dashboards.length !== 0 else null
          ],
          rows: createDashboardRows(playground.dashboards, environment.endsWith('dev') and showPromote)
        }) }}

      {% endif %}


      {% else %}

        {{ appInfo({ html: "Switch to the <a href='./dev#dashboards'>Dev</a> environment to view the playground dashboards", isInverse: true}) }}

      {% endif %}

  {% endcall %}
</div>
