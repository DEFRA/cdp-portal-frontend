{% extends "layouts/page.njk" %}
{% from "../../components/resources-request/macro.njk" import resourcesRequest %}

{% block content %}

  {{ appPageHeading({
    text: "Resources request",
    intro: "Requested at " + resourceRequest.requestedAt
  }) }}

  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">

      {{ resourcesRequest({
        request: resourceRequest.resources
      }) }}

      </div>
    </div>
  </section>

{% endblock %}
