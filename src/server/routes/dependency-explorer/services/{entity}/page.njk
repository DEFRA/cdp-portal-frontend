{% extends "layouts/page.njk" %}
{% from "./components/dependency-row/macro.njk" import dependencyRow %}

{% block content %}
  {{ appPageHeading({
    text: entity,
    intro: 'Dependencies'
  }) }}

  {% block xhrContent %}
    {% call appFilters({
      action: pageUrl,
      clear: {
        url: pageUrl
      },
      info: {
        html: appEntityDataList({
          items:  [
            {
              heading: {
                text: 'Count'
              },
              entity: {
                kind: 'text',
                value: totalItems | formatNumber,
                title: totalItems,
                dataXhr: 'resultsCount',
                dataJs: 'rows-loader'
              }
            }
          ]
        })
      },
      loader: 'rows-loader'
    }) %}


    <div class="app-filters__item">
      {{ govukInput({
        id: "entityVersion",
        name: "entityVersion",
        classes: "app-input app-input--tiny app-input--block",
        label: {
          text: "Service version",
          classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
        },
        formGroup: {
          classes: "app-form-group--inline"
        },
        value: query.entityVersion,
        placeholder: "Version"
      }) }}
    </div>

    {{ appAutocomplete({
      id: "dependencyName",
      name: "dependencyName",
      classes: "app-autocomplete--search-medium app-autocomplete--inline",
      label: {
        text: "Dependency name",
        classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
      },
      icon: appSearchIcon(),
      formGroup: {
        classes: "app-form-group--inline"
      },
      value: dependencyName,
      disableLunrSpecialCharactersFilter: true,
      suggestionClasses: "app-autocomplete__suggestion--leading-hint",
      dataFetcher: {
        name: "searchDependencyName",
        loader: "search-dependency-loader"
      },
      loader: {
        name: "search-dependency-loader"
      },
      placeholder: "Search by dependency"
    }) }}

    <div class="app-filters__item">
      {{ appAutocomplete({
      id: "dependencyType",
      name: "dependencyType",
      classes: "app-autocomplete--tiny app-autocomplete--inline",
      label: {
        text: "Dependency type",
        classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
      },
      formGroup: {
        classes: "app-form-group--inline"
      },
      value: query.dependencyType,
      suggestions: dependencyTypeOptions
      }) }}
    </div>

    <div class="app-filters__item">
      {{ govukInput({
        id: "dependencyVersion",
        name: "dependencyVersion",
        classes: "app-input app-input--tiny app-input--block",
        label: {
          text: "Dependency version",
          classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
        },
        formGroup: {
          classes: "app-form-group--inline"
        },
        value: query.dependencyVersion,
        attributes: {
          placeholder: "Version"
        }
      }) }}
    </div>

  {% endcall %}


    <div data-xhr="results">
      {% call(params) appEntityTable(tableData) %}
        {{  dependencyRow({
          rowClasses: params.rowClasses,
          loopIndex: params.loopIndex,
          entity: entity,
          entityVersion: params.row.entityVersion,
          entityTags: params.row.entityTags,
          entityStage: params.row.entityStage,
          dependencyName: params.row.dependencyName,
          dependencyVersion: params.row.dependencyVersion,
          dependencyType: params.row.dependencyType
        }) }}
      {% endcall %}
    </div>
  {% endblock %}

{% endblock %}
