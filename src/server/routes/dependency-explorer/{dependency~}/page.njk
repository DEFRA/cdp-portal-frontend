{% extends "layouts/page.njk" %}
{% from "./components/entity-row/macro.njk" import entityRow %}

{% block content %}
  {{ appPageHeading({
    text: "Dependency Explorer",
    intro: "View the services which are using a dependency"
  }) }}

  <script>

    function updatePath() {
      const filtersForm = document.querySelector("form[data-js='app-filters']")
      if (filtersForm) {
        filtersForm.setAttribute('action', window.location.pathname)
      }
    }

  </script>

  <form id="dependencyForm" action="" method="POST" data-js="auto-refresh" data-auto-refresh-loader="results-loader" data-on-refresh="updatePath">
    <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />

    {% call govukFieldset() %}

    <div style="display: flex; align-items: end;">
      {{ appAutocomplete({
        id: "dependencyInput",
        name: "dependency",
        classes: "app-autocomplete--search-medium app-autocomplete--inline",
        label: {
          text: "Dependency name",
          classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
        },
        icon: appSearchIcon(),
        formGroup: {
          classes: "app-form-group--inline"
        },
        value: dependencyType + ':' + dependencyName if dependencyType or dependencyName,
        template: 'search',
        disableLunrSpecialCharactersFilter: true,
        disableAutoSubmit: true,
        suggestionClasses: "app-autocomplete__suggestion--leading-hint",
        dataFetcher: {
          name: "searchDependencyName",
          loader: "search-dependency-loader"
        },
        loader: {
          name: "search-dependency-loader"
        },
        placeholder: "Search by dependency"
      }) }}
      {{ appLoader({ name: 'results-loader', classes: 'govuk-!-margin-bottom-2 govuk-!-margin-left-2' }) }}
    </div>

      <div class="govuk-body govuk-!-margin-top-4">
        {{ govukButton({
          classes: "app-button js-hidden",
          text: "View services"
        }) }}
      </div>

    {% endcall %}

  </form>

  {% block xhrContent %}
    {% call appFilters({
      action: pageUrl,
      clear: {
        url: pageUrl
      },
      info: {
        html: appEntityDataList({
          items:  [
            {
              heading: {
                text: 'Count'
              },
              entity: {
                kind: 'text',
                value: totalItems | formatNumber,
                title: totalItems,
                dataXhr: "resultsCount",
                dataJs: 'rows-loader'
              }
            }
          ]
        })
      },
      loader: 'rows-loader'
    }) %}

    <div class="app-filters__item">
      {{ appAutocomplete({
        id: "entity",
        name: "entity",
        classes: "app-autocomplete--small app-autocomplete--inline",
        label: {
          text: "Service name",
          classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
        },
        formGroup: {
          classes: "app-form-group--inline"
        },
        value: query.entity,
        suggestions: entityOptions
      }) }}
    </div>

      <div class="app-filters__item">
        {{ govukInput({
          id: "versionStart",
          name: "versionStart",
          classes: "app-input app-input--medium app-input--block",
          label: {
            text: "Dependency version from",
            classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
          },
          formGroup: {
            classes: "app-form-group--inline"
          },
          value: query.versionStart,
          attributes: {
            placeholder: "Start version"
          }
        }) }}
      </div>

      <div class="app-filters__item">
        {{ govukInput({
          id: "versionEnd",
          name: "versionEnd",
          classes: "app-input app-input--medium app-input--block",
          label: {
            text: "Dependency version to",
            classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
          },
          formGroup: {
            classes: "app-form-group--inline"
          },
          value: query.versionEnd,
          attributes: {
            placeholder: "End version"
          }
        }) }}
      </div>

      <div class="app-filters__item">
        {{ appAutocomplete({
          id: "team",
          name: "team",
          classes: "app-autocomplete--small app-autocomplete--inline",
          label: {
            text: "Team",
            classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
          },
          formGroup: {
            classes: "app-form-group--inline"
          },
          value: query.team,
          suggestions: teamOptions
        }) }}
      </div>

      <div class="app-filters__item">
        {{ appAutocomplete({
          id: "environment",
          name: "environment",
          classes: "app-autocomplete--tiny app-autocomplete--inline",
          label: {
            text: "Environment",
            classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
          },
          formGroup: {
            classes: "app-form-group--inline"
          },
          value: query.environment,
          suggestions: environmentOptions
        }) }}
      </div>

      <div class="app-filters__item">
        {{ appAutocomplete({
          id: "tag",
          name: "tag",
          classes: "app-autocomplete--tiny app-autocomplete--inline",
          label: {
            text: "Service tag",
            classes: "govuk-label--s app-label--inline govuk-!-margin-bottom-1"
          },
          formGroup: {
            classes: "app-form-group--inline"
          },
          value: query.tag,
          suggestions: tagOptions
        }) }}
      </div>

    {% endcall %}


      <div data-xhr="results">
        {% call(params) appEntityTable(tableData) %}
          {{  entityRow({
            rowClasses: params.rowClasses,
            loopIndex: params.loopIndex,
            dependencyType: dependencyType,
            dependencyName: dependencyName,
            entity:  params.row.entity,
            entityVersion: params.row.entityVersion,
            entityStage: params.row.entityStage,
            entityTags: params.row.entityTags,
            teams: params.row.teams,
            dependencyVersion: params.row.dependencyVersion,
            envs: params.row.envs
          }) }}
        {% endcall %}
      </div>
    {% endblock %}

{% endblock %}
