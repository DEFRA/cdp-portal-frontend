{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-main-wrapper app-main-wrapper">

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third-from-desktop-wide">

        {{ appPageHeading({
          caption: "Remove resource from request",
          text: resourceTypeLabel | capitalize| replace("_", " ") | uppercaseMatch(["sqs", "sns", "sql", "api", "ai"])
        }) }}

        {% block formContent %}{% endblock %}

      </div>
    </div>

  </div>

{% endblock %}
