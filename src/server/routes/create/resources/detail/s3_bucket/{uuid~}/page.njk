{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-main-wrapper app-main-wrapper">

    {{ appPageHeading({
      caption: "Create Resource",
      text: "S3 Bucket"
    }) }}

    {{ appAutocomplete({
      id: "service",
      name: "service",
      label: {
        text: "Service",
        classes: "app-label"
      },
      hint: {
        text: 'Select the microservice to add the bucket to'
      },
      formGroup: {
        classes: "app-form-group app-form-group-js"
      },
      value: formValues.service,
      suggestions: entityOptions,
      errorMessage: errorMessageHelper(formErrors.service.message)
    }) }}

    {{ govukInput({
      name: "bucketName",
      label: {
        text: "Bucket name",
        classes: "app-label"
      },
      classes: "app-input app-input--wide",
      hint: {
        html: "A prefix and suffix will automatically be added to the bucket name. See <a href='/documentation/how-to/buckets.md#bucket-naming'>Bucket Naming documentation</a>",
        classes: "app-hint"
      },
      formGroup: {
        classes: "app-form-group"
      },
      value: formValues.bucketName,
      errorMessage: errorMessageHelper(formErrors.bucketName.message)
    }) }}


    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h1 class="govuk-fieldset__heading">
          Environments
        </h1>
      </legend>
      <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" data-govuk-checkboxes-init="">
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments" name="alertEnvironments" type="checkbox" value="infra-dev">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments">
            Infra-dev
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-2" name="alertEnvironments" type="checkbox" value="management">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-2">
            Management
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-3" name="alertEnvironments" type="checkbox" value="dev">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-3">
            Dev
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-4" name="alertEnvironments" type="checkbox" value="test">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-4">
            Test
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-5" name="alertEnvironments" type="checkbox" value="perf-test">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-5">
            Perf-test
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-6" name="alertEnvironments" type="checkbox" value="ext-test">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-6">
            Ext-test
          </label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="alertEnvironments-7" name="alertEnvironments" type="checkbox" value="prod">
          <label class="govuk-label govuk-checkboxes__label" for="alertEnvironments-7">
            Prod
          </label>
        </div>
      </div>
    </fieldset>
    <br/><br/>

    <div class="govuk-body govuk-button-group">
      {{ govukButton({
        classes: "app-button",
        text: "Add"
      }) }}

      <a class="app-link" href="/create/resources/detail">Cancel</a>
    </div>

  </div>

{% endblock %}
