{% from "govuk/components/select/macro.njk" import govukSelect %}

{% macro selectField(params) %}
  {{ govukSelect({
    id: params.name,
    name: params.name,
    label: {
      text: params.resolveLabel(params.def, params.name),
      classes: "app-label"
    },
    classes: "app-select",
    hint: {
      text: params.def.flags.description,
      classes: "app-hint"
    },
    formGroup: {
      classes: "app-form-group app-form-group-js"
    },
    items: params.resolveMeta(params.def, 'suggestions'),
    value: params.formValues[params.name],
    errorMessage: errorMessageHelper(params.formErrors[params.name].message)
  }) }}
{% endmacro %}
