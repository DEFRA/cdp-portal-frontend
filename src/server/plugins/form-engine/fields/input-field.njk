{% from "govuk/components/input/macro.njk" import govukInput %}

{% macro inputField(params) %}
  {{ govukInput({
    id: params.name,
    name: params.name,
    label: {
      text: params.resolveLabel(params.def, params.name),
      classes: "app-label"
    },
    classes: "app-input app-input--wide",
    formGroup: {
      classes: "app-form-group app-form-group-js"
    },
    hint: {
      html: params.def.flags.description,
      classes: "app-hint"
    },
    attributes: {
      "data-1p-ignore": ""
    },
    value: params.formValues[params.name],
    errorMessage: errorMessageHelper(params.formErrors[params.name].message)
  }) }}
{% endmacro %}
