{% from "govuk/components/textarea/macro.njk" import govukTextarea %}

{% macro textareaField(params, helpers) %}
  {{ govukTextarea({
    id: params.name,
    name: params.name,
    label: {
      text: helpers.resolveLabel(params.def, params.name),
      classes: "app-label"
    },
    hint: {
      html: params.def.flags.description,
      classes: "app-hint"
    },
    classes: "app-input app-input--wide",
    formGroup: {
      classes: "app-form-group app-form-group-js"
    },
    hint: {
      html: params.def.flags.description,
      classes: "app-hint"
    },
    attributes: {
      "data-1p-ignore": ""
    },
    value: params.formValues[params.name],
    errorMessage: errorMessageHelper(params.formErrors[params.name].message)
  }) }}
{% endmacro %}
