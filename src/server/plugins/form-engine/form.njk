{% extends layout %}

{% block formContent %}

  <form method="post" data-js="app-form-errors">
    <input type="hidden" name="csrfToken" value="{{ csrfToken }}"/>

    {% call govukFieldset() %}

      {% for name, def in fields %}

        {{ resolveComponent(def)({
          label: {
            text: def.flags.label or name,
            classes: "app-label"
          },
          id: name,
          name: name,
          classes: "app-input app-input--wide",
          formGroup: {
            classes: "app-form-group app-form-group-js"
          },
          hint: {
            text: def.flags.description,
            classes: "app-hint"
          },
          attributes: {
            "data-1p-ignore": ""
          },
          value: formValues[name],
          errorMessage: errorMessageHelper(formErrors[name].message)
        }) }}

      {% endfor %}

    {% endcall %}

    <div class="govuk-button-group">
      {{ govukButton({
        classes: "app-button",
        text: "Save",
        name: 'actionButton',
        value: 'submit'
      }) }}
      {{ govukButton({
        classes: "app-button  app-button--tertiary",
        text: "Cancel",
        name: 'actionButton',
        value: 'cancel'
      }) }}
    </div>

  </form>

{% endblock %}
