<tr class="{{ params.rowClasses }}" data-testid="app-entity-table-row-{{ params.loopIndex }}">
  {% for env in params.envs %}
    <td headers="{{ env.id }}" class="app-entity-table__cell">
      {% if not env.resource %}
        - - -
      {% else  %}
        <a href="/services/{{ params.entity.name }}/resources/{{ env.id }}#{{ env.resource.name }}" style="word-break: break-word; {% if env.resource.resourceRequestId %}color: darkGrey;{% endif %}">{{ env.resource.name }}</a>
      {% endif %}
    </td>
  {% endfor %}
</tr>
