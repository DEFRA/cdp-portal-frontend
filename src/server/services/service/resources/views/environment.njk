{% extends "layouts/tabbed-page.njk" %}

{% from "icons/pending-icon/macro.njk" import appPendingIcon %}
{% from "icons/tick-icon/macro.njk" import appTickIcon %}
{% from "info/macro.njk" import appInfo %}
{% from "loader/macro.njk" import appLoader %}
{% from "tag/macro.njk" import appTag %}
{% from "tool-tip/macro.njk" import appToolTip %}
{% from "services/common/components/resources-intro/macro.njk" import appResourcesIntro %}
{% from "../components/resource-value/macro.njk" import resourceValue %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Resources",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          {{ appResourcesIntro({
            caption: environment | title,
            heading: "Resources",
            entity: entity,
            hasBuckets: resources.s3_buckets | length
          }) }}

          {% if hasNoResources %}

            {{ appInfo({ html: "There are currently no resources defined for this service" }) }}

          {% else %}

            <pre class="mermaid mermaid--no-label-background mermaid--table-node">
              flowchart LR
                  service@{ icon: "logos:aws-fargate-{{ entity.subType.toLowerCase() }}", h: 80, label: "{{ entity.name}}"}

                  {% for type, items in resources | dictsort %}
                    {% if items | length %}
                      subgraph {{ type }}[{{ type | capitalize| replace("_", " ") | uppercaseMatch(["sqs", "sns", "sql", "api", "ai"]) }}]
                        direction LR
                        {% for resource in items %}
                          {{ type }}{{ resource.name }}Icon@{ icon: "logos:{{ resource.icon }}", h: 80, label: "<span id='{{ resource.name }}'>{{ resource.name }}</span>"}
                          {{ type }}{{ resource.name }}[<table>{% for name, value in resource.properties | dictsort %}
                            {% if name != 'name' and name != 'bucket_name'  %}<tr><th>{{ name | replace("_", " ") | capitalize }}</th><td>{{ resourceValue(value) | trim }}</td></tr>{% endif %}
                          {% endfor %}</table>]
                          {{ type }}{{ resource.name }}Icon ~~~ {{ type }}{{resource.name}}
                        {% endfor %}
                      end
                      service --- {{ type }}
                    {% endif %}
                  {% endfor %}
            </pre>

          {% endif %}

          <p class="govuk-!-margin-top-2">
            <a href="?debug=true" class="govuk-link app-link app-link--underline">Debug view</a>
          </p>

        {% endcall %}
      </div>
    </div>
  </section>
{% endblock %}


{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath("src/client/javascripts/mermaid.js") }}"></script>
{% endblock %}
