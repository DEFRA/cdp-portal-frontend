{% extends "layouts/tabbed-page.njk" %}

{% from "govuk/components/table/macro.njk" import govukTable %}

{% from "info/macro.njk" import appInfo %}
{% from "panel/macro.njk" import appPanel %}

{% set bucketNamesInfoHtml %}
  Why do bucket names have random characters at the end?
  <a class="app-link app-link--underline" href="/documentation/how-to/buckets.md#bucket-naming"
     target="_blank"
     rel="noopener noreferrer">See Bucket Naming documentation</a> for more details
{% endset %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Resources",
    text: entity.name
  }) }}

  {% include "partials/entity/messages.njk" %}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">

        {% call appSplitPane() %}
          <section>
            <h2 class="govuk-heading-l govuk-!-margin-bottom-2">Resources</h2>
            <p class="govuk-!-margin-bottom-2">
              View AWS resources for {{ entity.name }} in all CDP environments.
            </p>
            <p>
              To set up resources read <a href="/documentation/how-to/buckets.md"
                                          class="govuk-link app-link app-link--underline"
                                          target="_blank" rel="noopener noreferrer">S3 buckets</a>,
              <a href="/documentation/how-to/sqs-sns.md"
                 class="govuk-link app-link app-link--underline"
                 target="_blank" rel="noopener noreferrer">SQS Queues and SNS Topics</a>
              then contact the Platform team via Slack
              <a class="app-link app-link--underline" href="{{ supportChannel }}" target="_blank"
                 rel="noopener noreferrer">#cdp-support</a>
            </p>

            {{ appInfo({ html: bucketNamesInfoHtml }) }}

            <div class="app-grid app-grid--fluid">

              {% for environment, detail in resourcesByEnvironment %}
                {% call appPanel({ classes: "app-row" }) %}
                  <div class="app-row__item-flex-one">
                    <span class="govuk-caption-m">{{ environment | title }}</span>
                    <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
                      S3 Buckets
                    </h3>

                    {% if detail.s3BucketRows | length %}
                      {{ govukTable({
                        classes: "app-table app-table--inverse govuk-!-margin-bottom-6",
                        rows: detail.s3BucketRows
                      }) }}
                    {% else %}
                      <p class="govuk-!-margin-top-2">
                        S3 Buckets not set up for this environment
                      </p>
                    {% endif %}

                    <hr class="app-section-break app-section-break--slim">

                    <span class="govuk-caption-m">{{ environment | title }}</span>
                    <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
                      SQS Queues
                    </h3>

                    {% if detail.sqsQueues | length %}
                      {% for summary in detail.sqsQueues %}
                        {{ govukSummaryList(summary) }}
                      {% endfor %}
                    {% else %}
                      <p class="govuk-!-margin-top-2">
                        SQS Queues not set up for this environment
                      </p>
                    {% endif %}

                    <hr class="app-section-break app-section-break--slim">

                    <span class="govuk-caption-m">{{ environment | title }}</span>
                    <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
                      SNS Topics
                    </h3>

                    {% if detail.snsTopics | length %}
                      {% for summary in detail.snsTopics %}
                        {{ govukSummaryList(summary) }}
                      {% endfor %}
                    {% else %}
                      <p class="govuk-!-margin-top-2">
                        SNS Topics not set up for this environment
                      </p>
                    {% endif %}

                  </div>
                {% endcall %}
              {% endfor %}
            </div>
          </section>
        {% endcall %}

      </div>
    </div>
  </section>

{% endblock %}
