{% extends "layouts/tabbed-page.njk" %}

{% set warningHtml %}
  <p class="govuk-!-margin-bottom-1">
    When a services url has been shuttered all requests to the service and any of its paths will be redirected to the
    shutter page
  </p>
{% endset %}

{% set infoHtml %}
  <p class="govuk-!-margin-bottom-1">
    Un-shuttering a services url will mean that all requests to the service and any of its paths will return to normal
    and will serve your application as intended
  </p>
{% endset %}

{% set summaryHeading %}
  {% if isShuttered %}
    Un-shutter the following service url
  {% endif %}

  {% if not isShuttered %}
    Shutter the following service url
  {% endif %}
{% endset %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Confirm shutter",
    text: entity.name
  }) }}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half-from-desktop">

        {% if isShuttered %}
          <div class="govuk-!-margin-bottom-2">
            {{ appInfo({
              html: infoHtml
            }) }}
          </div>
        {% endif %}

        {% if not isShuttered %}
          <div class="govuk-!-margin-bottom-2">
            {{ appWarning({
              html: warningHtml
            }) }}
          </div>
        {% endif %}

        {% call appPanel() %}
          <h2 class="govuk-heading-m">{{ summaryHeading }}</h2>

          {{ govukSummaryList(summaryList) }}
        {% endcall %}

        {% call appPanel() %}
          <form
            action="{{ routeLookup('post:services/{serviceId}/shuttering/confirm', { params: { serviceId: entity.name } }) }}"
            method="POST"
            data-js="app-form-group">

            <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
            <input type="hidden" name="serviceName" value="{{ shutteringDetail.serviceName }}" />
            <input type="hidden" name="environment" value="{{ shutteringDetail.environment }}" />
            <input type="hidden" name="waf" value="{{ shutteringDetail.waf }}" />
            <input type="hidden" name="url" value="{{ shutteringDetail.url }}" />

            <div class="govuk-body govuk-button-group govuk-!-margin-bottom-0">

              {% if isShuttered %}
                {{ govukButton({
                  classes: "app-button",
                  text: "Un-shutter url"
                }) }}
              {% endif %}

              {% if not isShuttered %}
                {{ govukButton({
                  classes: "app-button app-button--destructive",
                  text: "Shutter url"
                }) }}
              {% endif %}

              <a class="app-link"
                 href="{{ routeLookup('services/{serviceId}/shuttering', { params: { serviceId: entity.name } }) }}">Cancel</a>
            </div>
          </form>
        {% endcall %}
      </div>
    </div>
  </section>
{% endblock %}
