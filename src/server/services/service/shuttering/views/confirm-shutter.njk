{% extends "layouts/tabbed-page.njk" %}

{% set warningHtml %}
  <p class="govuk-!-margin-bottom-1">
    When a service has been shuttered all requests to the service are redirected to the shutter page
  </p>
{% endset %}

{% block beforeTabContent %}
  {{ appPageHeading({
    caption: "Confirm shutter",
    text: entity.name
  }) }}
{% endblock %}

{% block tabContent %}
  <section class="govuk-!-margin-top-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half-from-desktop">

        <div class="govuk-!-margin-bottom-2">
          {{ appWarning({
            html: warningHtml,
            isInverse: true
          }) }}
        </div>

        {% call appPanel() %}
          <h2 class="govuk-heading-m">Shutter the following service url</h2>

          {{ govukSummaryList(summaryList) }}
        {% endcall %}

        {% call appPanel() %}
          <form
            action="{{ routeLookup('post:services/{serviceId}/shuttering', { params: { serviceId: entity.name } }) }}"
            method="POST"
            data-js="app-form-group">

            <input type="hidden" name="csrfToken" value="{{ csrfToken }}" />
            <input type="hidden" name="serviceName" value="{{ entity.name }}" />
            <input type="hidden" name="environment" value="{{ environment }}" />

            <div class="govuk-body govuk-button-group govuk-!-margin-bottom-0">
              {{ govukButton({
                classes: "app-button app-button--destructive",
                text: "Shuter service"
              }) }}

              <a class="app-link" href="{{ routeLookup('services/{serviceId}/shuttering', { params: { serviceId: entity.name } }) }}">Cancel</a>
            </div>
          </form>
        {% endcall %}
      </div>
    </div>
  </section>
{% endblock %}
