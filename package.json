{
  "name": "cdp-portal-frontend",
  "version": "1.0.0",
  "description": "CDP Portal Frontend",
  "license": "OGL-UK-3.0",
  "author": "Defra DDTS",
  "sideEffects": false,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "run-s build:client",
    "build:client": "vite build",
    "dev": "nodemon --ext js,json --watch ./src/server --watch ./src/config --env-file-if-exists=.env ./src",
    "dev:debug": "nodemon --ext js,json --watch ./src/server --watch ./src/config --env-file-if-exists=.env --inspect ./src",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,md,json,config.js,test.js}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,md,json,config.js,test.js}\"",
    "git:hooks": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "lint": "run-s lint:js lint:scss",
    "lint:fix": "eslint --fix .",
    "lint:js": "eslint .",
    "lint:scss": "stylelint  \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "prepreview": "npm run build:client",
    "preview": "NODE_ENV=production node --env-file-if-exists=.env .",
    "security-audit": "npm audit --audit-level=high",
    "start": "npm run dev",
    "start:debug": "npm run dev:debug",
    "pretest": "npm run build:client",
    "test": "NODE_ENV=test TZ=UTC vitest --coverage",
    "test:watch": "npm run test"
  },
  "imports": {
    "#server/*": "./src/server/*",
    "#config/*": "./src/config/*",
    "#client/*": "./src/client/*",
    "#test-helpers/*": "./test-helpers/*"
  },
  "overrides": {
    "fast-xml-parser": "5.5.9",
    "lodash-es": "4.18.1",
    "serialize-javascript": "7.0.3",
    "tmp": "0.2.5"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity": "3.1016.0",
    "@aws-sdk/client-firehose": "3.986.0",
    "@aws-sdk/client-s3": "3.986.0",
    "@aws-sdk/credential-providers": "3.986.0",
    "@babel/runtime": "7.29.2",
    "@defra/catbox-dynamodb": "0.7.1",
    "@defra/cdp-auditing": "0.5.0",
    "@defra/cdp-metrics": "0.2.0",
    "@defra/cdp-validation-kit": "0.63.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/basic": "7.0.2",
    "@hapi/bell": "13.1.0",
    "@hapi/boom": "10.0.1",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/cookie": "12.0.1",
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "21.4.7",
    "@hapi/hoek": "11.0.7",
    "@hapi/inert": "7.1.0",
    "@hapi/jwt": "3.2.3",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "18.1.0",
    "@hapi/yar": "11.0.3",
    "@smithy/node-http-handler": "4.5.1",
    "@smithy/property-provider": "4.2.10",
    "bcrypt": "6.0.0",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "date-fns": "4.1.0",
    "disinfect": "2.0.0",
    "fast-glob": "3.3.3",
    "get-form-data": "3.0.0",
    "govuk-frontend": "5.14.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "highlight.js": "11.11.1",
    "history": "5.3.0",
    "ioredis": "5.10.1",
    "joi": "18.0.2",
    "lodash": "4.18.1",
    "lunr": "2.3.9",
    "marked": "16.2.1",
    "marked-alert": "2.1.2",
    "marked-plaintify": "1.1.1",
    "mermaid": "11.12.3",
    "nunjucks": "3.2.4",
    "openid-client": "6.8.2",
    "p-retry": "8.0.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "qs": "6.15.0",
    "semver": "7.7.4",
    "string-strip-html": "13.5.3",
    "undici": "7.24.6",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@defra/hapi-connect": "1.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "1.6.13",
    "cheerio": "1.2.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-package-json": "0.88.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "filenamify": "7.0.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jest-environment-jsdom": "30.2.0",
    "jest-file-snapshot": "0.7.0",
    "neostandard": "0.12.2",
    "nock": "14.0.11",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "sass-embedded": "1.98.0",
    "stylelint": "16.25.0",
    "stylelint-config-gds": "2.0.0",
    "vite": "8.0.5",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
